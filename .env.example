# Paste your Anthropic API key here — server/index.js reads it, the browser never sees it.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Port for the Express proxy (server/index.js). vite.config.js proxies /api here.
PORT=8787

# Proxy hardening (server/index.js)
CLAUDE_RATE_MAX=20     # max POST /api/claude requests per minute per IP
BODY_LIMIT=100kb       # max request body size

# NEO4J seam (optional). Off by default -> server uses the JSON file store.
# Set USE_NEO4J=true and fill these to mirror complaints into Neo4j AuraDB.
USE_NEO4J=false
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
